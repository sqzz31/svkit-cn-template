{
  "$schema": "https://wails.io/schemas/v3/config.json",
  "name": "{{.Name}}",
  "author": "{{.Name}}",
  "info": {
    "productName": "{{.Name}}",
    "productVersion": "1.0.0",
    "productDescription": "SvelteKit Template for Wails v3 with Iconify support"
  },
  "frontend:dir": "frontend",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:server:url": "http://localhost:5173",
  "wailsjs:dir": "./frontend/src/lib/wailsjs"
}

